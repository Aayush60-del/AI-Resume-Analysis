# --- Local development (npm run dev) ---
# Vite proxy forwards /api → http://localhost:5000
VITE_API_URL=/api

# --- Production (Vercel) — copy this to Vercel Environment Variables ---
# Must be your Render backend URL with /api suffix (no trailing slash after api)
# VITE_API_URL=https://ai-resume-analysis.onrender.com/api
